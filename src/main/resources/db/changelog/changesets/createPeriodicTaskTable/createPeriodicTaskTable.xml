<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create_periodic_task_table" author="Vladimir.Berman">
        <createSequence cycle="false" incrementBy="1" sequenceName="periodic_task_id_seq"/>

        <createTable tableName="periodic_task">
            <column name="id" type="int" defaultValueSequenceNext="periodic_task_id_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="class_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="method_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="interval_seconds" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValue="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="periodic_task"/>
            <dropSequence sequenceName="periodic_task_id_seq"/>
        </rollback>
    </changeSet>
</databaseChangeLog>